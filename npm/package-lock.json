{
  "name": "heroparser-workspace",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "heroparser-workspace",
      "workspaces": [
        "packages/*",
        "examples/*",
        "tests"
      ]
    },
    "node_modules/heroparser": {
      "resolved": "packages/heroparser-wasm",
      "link": true
    },
    "node_modules/heroparser-tests": {
      "resolved": "tests",
      "link": true
    },
    "packages/heroparser-wasm": {
      "name": "heroparser",
      "version": "2.5.2",
      "license": "MIT"
    },
    "tests": {
      "name": "heroparser-tests",
      "dependencies": {
        "heroparser": "file:../packages/heroparser-wasm"
      }
    }
  }
}
